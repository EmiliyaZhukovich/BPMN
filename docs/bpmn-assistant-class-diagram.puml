@startuml bpmn-assistant-class-diagram
title BPMN Assistant — диаграмма классов

skinparam shadowing false
skinparam handwritten false
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 45
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam package {
  BackgroundColor #F4F7FB
  BorderColor #5C7CA6
  FontStyle bold
  FontColor #2C3E50
}
skinparam class {
  BackgroundColor #FFFFFF
  BorderColor #3D5A80
  FontColor #1A2B3C
}
skinparam arrow {
  Color #4A5568
  FontSize 10
}
skinparam note {
  BackgroundColor #FFFDF5
  BorderColor #D4C48A
  FontSize 10
}

' --- Клиент ---
package "Клиентское приложение (Vue.js)" as PKG_CLIENT {

  class ГлавныйЭкран {
    - xmlДиаграммы: строка
    - модельер: «внешний компонент»
    --
    + обработатьXmlПослеКонструктора()
    + запроситьАвторазметкуНаСервере()
    + экспортироватьPng()
    + экспортироватьSvg()
  }

  class ПанельКонструктора {
    - диаграмма: МодельДиаграммы
    - стекОтмены: список
    --
    + построитьДиаграмму()
    + загрузитьШаблон()
    + импортироватьИзФайла()
    + отменитьИзменение()
    + повторитьИзменение()
  }

  class МодельДиаграммы {
    .. Объекты потока ..
    - события: список
    - активности: список
    - шлюзы: список
    .. Данные ..
    - объектыДанных: список
    - хранилищаДанных: список
    .. Соединители ..
    - потокУправления: список
    - ассоциации: список
    .. Дорожки ..
    - пулПроцесса: Пул
    - дорожкиРолей: список
    .. Артефакты ..
    - аннотации: список
  }

  class ГенераторBpmnXml <<утилита>> {
    {static} + сформироватьXml(диаграмма): строка
  }
}

class МодельерBpmn <<внешняя библиотека>> {
  + импортироватьXml()
  + сохранитьSvg()
  + масштабироватьВид()
}

' --- Сервер ---
package "Сервер API (FastAPI)" as PKG_SERVER {

  class ПриложениеApi {
    --
    + эндпоинтПреобразованияВJson()
    + эндпоинтРазметкиДиаграммы()
  }

  class ЗапросПреобразованияBpmn {
    + bpmn_xml: строка
  }

  class ЗапросРазметкиBpmn {
    + bpmnXml: строка
  }

  class ГенераторBpmnJson {
    - узлыПоId: отображение
    - потокиУправленияПоId: отображение
    - деревоПроцессаДляJson: список
    --
    + создатьJsonИзXml(xml: строка): список
  }

  class СервисРазметкиBpmn {
    - скриптРазметки: путьКФайлу
    --
    + обработатьBpmn(xml: строка): строка
  }
}

' --- База данных (персистенция) ---
package "База данных (PostgreSQL)" as PKG_DB {

  class пользователи <<таблица>> {
    + id: uuid
    + email: text
    + password_hash: text
    + created_at: timestamptz
  }

  class сохранённые_модели <<таблица>> {
    + id: uuid
    + user_id: uuid
    + title: text
    + bpmn_xml: text
    + updated_at: timestamptz
  }

  пользователи "1" -- "0..*" сохранённые_модели : «FK user_id»
}

' --- Три вида отношений (по учебнику UML) ---
' *-- композиция | --> ассоциация (сплошая) | ..> зависимость (пунктир)

' Композиция: часть не имеет смысла без целого
ГлавныйЭкран *-right-- ПанельКонструктора : «1»\nкомпозиция
ПанельКонструктора *-right-- МодельДиаграммы : композиция\n«состояние конструктора»

' Ассоциация: устойчивое использование функционала / обмен по контракту
ГлавныйЭкран -down-> ПриложениеApi : ассоциация\nHTTP «/process-bpmn»\n(базовый URL бэкенда)
ПанельКонструктора -down-> ГенераторBpmnXml : ассоциация\n«вызывает утилиту XML»
ПриложениеApi -down-> ЗапросПреобразованияBpmn : ассоциация\n«/bpmn_to_json»
ПриложениеApi -down-> ЗапросРазметкиBpmn : ассоциация\n«/process-bpmn»

' Зависимость: изменение «неизменного» класса может потребовать правки зависимого
ГлавныйЭкран .down.> МодельерBpmn : зависимость
ГенераторBpmnXml .right.> МодельДиаграммы : зависимость
ЗапросПреобразованияBpmn .down.> ГенераторBpmnJson : зависимость
ЗапросРазметкиBpmn .down.> СервисРазметкиBpmn : зависимость

ПриложениеApi .down.> PKG_DB : зависимость\n«доступ к данным:\nпользователи и сохранённые BPMN»


note bottom of МодельерBpmn
  Библиотека **bpmn-js**.
end note

note bottom of ГенераторBpmnJson
  Читает только **строку BPMN XML**,
  строит словари узлов и **sequenceFlow**, затем вложенный **список** процесса для JSON.
end note

@enduml
