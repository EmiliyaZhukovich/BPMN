@startuml bpmn-assistant-component-diagram
title BPMN Assistant — диаграмма компонентов

top to bottom direction

skinparam shadowing false
skinparam handwritten false
skinparam nodesep 55
skinparam ranksep 55
skinparam packageStyle rectangle
skinparam component {
  BackgroundColor #E8EEF7
  BorderColor #3D5A80
  FontColor #1A2B3C
}
skinparam artifact {
  BackgroundColor #FFFFFF
  BorderColor #8FA3B8
}
skinparam arrow {
  Color #4A5568
  FontSize 10
}

' ========== Сервер ==========
package "Сервер приложений\n(Python + FastAPI + Node.js)" as PKG_SERVER {

  component "FastAPI\n(REST API)" <<component>> as COMP_API

  together {
    component "Сервис авторазметки BPMN" <<component>> as COMP_LAYOUT
    component "Сервис преобразования\nBPMN XML → JSON" <<component>> as COMP_JSON
    component "Сервис сохранённых диаграмм" <<component>> as COMP_SAVED
  }

  artifact "Скрипт разметки\n(layout_process.js)" <<artifact>> as ART_LAYOUT
  artifact "Пакет Python-модулей" <<artifact>> as ART_PY
}

package "База данных (PostgreSQL)" as PKG_DB {
  database "PostgreSQL" as COMP_DB
}

' ========== Контракт ==========
() "HTTP REST\nBPMN Assistant API" as IF_REST

note right of IF_REST
  **Основные эндпоинты:**
  • POST /process-bpmn — генерация + разметка
  • POST /bpmn_to_json
  • GET /diagrams — список моделей
  • GET/PUT/DELETE /diagrams/{id} — работа с моделью
end note

' ========== Клиент ==========
package "Клиентское окружение\n(браузер)" as PKG_CLIENT {

  component "Одностраничное приложение\n«BPMN Assistant» (Vue.js)" <<component>> as COMP_SPA {
    component "Главная страница\n(дашборд)" <<component>> as COMP_DASH
    component "Редактор BPMN\n(конструктор + холст)" <<component>> as COMP_EDITOR
  }

  component "Библиотека bpmn-js" <<component>> as COMP_BPMNJS
  artifact "Сборка фронтенда (Vite)" <<artifact>> as ART_FE
}

' ========== Связи ==========
COMP_API -down- IF_REST : реализует
COMP_SPA -up..> IF_REST : использует

COMP_API -right..> COMP_DB : SQL
COMP_API -up..> COMP_LAYOUT
COMP_API -up..> COMP_JSON
COMP_API -up..> COMP_SAVED : CRUD операций

COMP_LAYOUT -down..> ART_LAYOUT : subprocess
COMP_SPA -left..> ART_FE : сборка

COMP_DASH -right..> COMP_EDITOR : Vue Router
COMP_EDITOR -down..> COMP_BPMNJS : визуализация

@enduml
